{"openapi": "3.1.0", "info": {"title": "FastAPI", "version": "0.1.0"}, "paths": {"/api/v1/processed/fields": {"get": {"tags": ["v1", "v1", "data"], "summary": "Get Processed Fields", "description": "Returns all known metric keys grouped by the event type that produces them.\n\nExample: {\"thrputUl_mbps_mean\": [\"PERF_DATA\"], \"speed_mean\": [\"UE_MOBILITY\"]}", "operationId": "get_processed_fields_api_v1_processed_fields_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/api/v1/processed": {"get": {"tags": ["v1", "v1", "data"], "summary": "Get Processed Data", "description": "Query processed analytics windows from ClickHouse.\n\nGroups are identified by snssai_sst + dnn + event. Additional UE-level tags\n(ueIpv4Addr, supi, etc.) are returned in the ue_tags field of each row.\nMetric stats are flattened: thrputUl_mbps_mean, thrputUl_mbps_min, etc.", "operationId": "get_processed_data_api_v1_processed_get", "parameters": [{"name": "start_time", "in": "query", "required": true, "schema": {"type": "integer", "description": "Window start (Unix timestamp, seconds)", "title": "Start Time"}, "description": "Window start (Unix timestamp, seconds)"}, {"name": "end_time", "in": "query", "required": true, "schema": {"type": "integer", "description": "Window end (Unix timestamp, seconds)", "title": "End Time"}, "description": "Window end (Unix timestamp, seconds)"}, {"name": "snssai_sst", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "S-NSSAI SST (slice type)", "title": "Snssai Sst"}, "description": "S-NSSAI SST (slice type)"}, {"name": "snssai_sd", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "S-NSSAI SD (slice differentiator, 6 hex digits)", "title": "Snssai Sd"}, "description": "S-NSSAI SD (slice differentiator, 6 hex digits)"}, {"name": "dnn", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "Data Network Name", "title": "Dnn"}, "description": "Data Network Name"}, {"name": "event", "in": "query", "required": false, "schema": {"anyOf": [{"type": "string"}, {"type": "null"}], "description": "Event type filter (e.g. PERF_DATA, UE_MOBILITY)", "title": "Event"}, "description": "Event type filter (e.g. PERF_DATA, UE_MOBILITY)"}, {"name": "window_duration_seconds", "in": "query", "required": false, "schema": {"anyOf": [{"type": "integer"}, {"type": "null"}], "description": "Window duration filter (seconds)", "title": "Window Duration Seconds"}, "description": "Window duration filter (seconds)"}, {"name": "offset", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 0, "description": "Records to skip", "default": 0, "title": "Offset"}, "description": "Records to skip"}, {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 1000, "minimum": 1, "description": "Max records to return", "default": 100, "title": "Limit"}, "description": "Max records to return"}, {"name": "X-Component-ID", "in": "header", "required": false, "schema": {"type": "string", "title": "X-Component-Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/raw": {"get": {"tags": ["v1", "v1", "data"], "summary": "Get Raw Data", "description": "Query raw data by time range and optional tag filters.\nAt least one tag filter is recommended for meaningful results.", "operationId": "get_raw_data_api_v1_raw_get", "parameters": [{"name": "start_time", "in": "query", "required": true, "schema": {"type": "integer", "description": "Start time (Unix timestamp in seconds)", "title": "Start Time"}, "description": "Start time (Unix timestamp in seconds)"}, {"name": "end_time", "in": "query", "required": true, "schema": {"type": "integer", "description": "End time (Unix timestamp in seconds)", "title": "End Time"}, "description": "End time (Unix timestamp in seconds)"}, {"name": "batch_number", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 1, "description": "Batch number", "default": 1, "title": "Batch Number"}, "description": "Batch number"}, {"name": "event", "in": "query", "required": false, "schema": {"type": "string", "title": "Event"}}, {"name": "ueIpv4Addr", "in": "query", "required": false, "schema": {"type": "string", "title": "Ueipv4Addr"}}, {"name": "supi", "in": "query", "required": false, "schema": {"type": "string", "title": "Supi"}}, {"name": "gpsi", "in": "query", "required": false, "schema": {"type": "string", "title": "Gpsi"}}, {"name": "dnn", "in": "query", "required": false, "schema": {"type": "string", "title": "Dnn"}}, {"name": "snssai_sst", "in": "query", "required": false, "schema": {"type": "string", "title": "Snssai Sst"}}, {"name": "snssai_sd", "in": "query", "required": false, "schema": {"type": "string", "title": "Snssai Sd"}}, {"name": "X-Component-ID", "in": "header", "required": false, "schema": {"type": "string", "title": "X-Component-Id"}}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}, "/api/v1/policy/fields": {"get": {"tags": ["v1", "v1", "policy"], "summary": "Get Available Fields", "description": "Get available fields from InfluxDB and ClickHouse.\n\nReturns:\n    Dictionary with 'influx' and 'clickhouse' field lists.", "operationId": "get_available_fields_api_v1_policy_fields_get", "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}}}}, "/api/v1/decisions": {"get": {"tags": ["v1", "v1", "decisions"], "summary": "Get Decisions", "description": "Query decision data with filters.\n\nReturns compressed decision data including:\n- cell_id: Cell identifier\n- id: Decision record ID\n- timestamp: When the decision was made\n- compression_method: Compression algorithm used (e.g., \"gzip\")\n- compressed_data: Base64-encoded compressed decision JSON\n\nTo decompress the data:\n1. Decode base64\n2. Decompress using the specified compression method\n3. Parse resulting JSON", "operationId": "get_decisions_api_v1_decisions_get", "parameters": [{"name": "start_time", "in": "query", "required": true, "schema": {"type": "integer", "description": "Start time (Unix timestamp in seconds)", "title": "Start Time"}, "description": "Start time (Unix timestamp in seconds)"}, {"name": "end_time", "in": "query", "required": true, "schema": {"type": "integer", "description": "End time (Unix timestamp in seconds)", "title": "End Time"}, "description": "End time (Unix timestamp in seconds)"}, {"name": "cell_id", "in": "query", "required": false, "schema": {"anyOf": [{"type": "integer"}, {"type": "null"}], "description": "Cell ID filter (optional)", "title": "Cell Id"}, "description": "Cell ID filter (optional)"}, {"name": "offset", "in": "query", "required": false, "schema": {"type": "integer", "minimum": 0, "description": "Number of records to skip", "default": 0, "title": "Offset"}, "description": "Number of records to skip"}, {"name": "limit", "in": "query", "required": false, "schema": {"type": "integer", "maximum": 1000, "minimum": 1, "description": "Maximum number of records to return", "default": 100, "title": "Limit"}, "description": "Maximum number of records to return"}], "responses": {"200": {"description": "Successful Response", "content": {"application/json": {"schema": {}}}}, "422": {"description": "Validation Error", "content": {"application/json": {"schema": {"$ref": "#/components/schemas/HTTPValidationError"}}}}}}}}, "components": {"schemas": {"HTTPValidationError": {"properties": {"detail": {"items": {"$ref": "#/components/schemas/ValidationError"}, "type": "array", "title": "Detail"}}, "type": "object", "title": "HTTPValidationError"}, "ValidationError": {"properties": {"loc": {"items": {"anyOf": [{"type": "string"}, {"type": "integer"}]}, "type": "array", "title": "Location"}, "msg": {"type": "string", "title": "Message"}, "type": {"type": "string", "title": "Error Type"}}, "type": "object", "required": ["loc", "msg", "type"], "title": "ValidationError"}}}}
